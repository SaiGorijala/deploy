# DevOps Pipeline Orchestrator - Environment Configuration

# Application Configuration
APP_NAME=DevOps Pipeline Orchestrator
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Ollama Configuration (via SSH Reverse Tunnel)
# Ensure SSH reverse tunnel is active: ssh -R 11434:127.0.0.1:11434 user@cloud-server
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-coder:6.7b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_SECONDS=300

# Workspace Configuration
WORKSPACE_ROOT=/tmp/devops_pipeline

# Pipeline Configuration
MAX_PIPELINE_RETRIES=3
PIPELINE_TIMEOUT_SECONDS=1800
SONARQUBE_POLLING_INTERVAL=5
SONARQUBE_MAX_POLLING_ATTEMPTS=120

# Docker Configuration
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Security Configuration
ENABLE_CLEANUP_ON_SUCCESS=true
ENABLE_CLEANUP_ON_FAILURE=false
SECURE_CREDENTIAL_HANDLING=true

# Health Check Configuration
HEALTH_CHECK_TIMEOUT_SECONDS=30
HEALTH_CHECK_MAX_RETRIES=5
HEALTH_CHECK_RETRY_INTERVAL=5

# Network Configuration
REQUEST_TIMEOUT_SECONDS=60
